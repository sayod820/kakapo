# ════════════════════════════════════════════
# KAKAPO Frontend — настройки
# ════════════════════════════════════════════

# Использовать backend API (true) или демо-данные (false)
NEXT_PUBLIC_USE_API=false

# Адрес backend сервера
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# В продакшене:
# NEXT_PUBLIC_API_URL=https://api.kakapo.tj
# NEXT_PUBLIC_WS_URL=wss://api.kakapo.tj
