# ── Production: Hetzner (всё на одном сервере) — рекомендуется ───────
# deploy/hetzner/.env + docker compose (см. deploy/hetzner/README.md)
# NEXT_PUBLIC_USE_API=true
# PUBLIC_URL=https://kakapo.tj
# WS_URL=wss://kakapo.tj
# KAKAPO_BACKEND_URL=http://api:8000   # внутри Docker

# ── Локальная разработка на ПК ───────────────────────────────────────
# NEXT_PUBLIC_USE_API=false

# ── Локальная разработка на ПК ───────────────────────────────────────
# NEXT_PUBLIC_USE_API=true
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
# KAKAPO_BACKEND_URL=http://localhost:8000
