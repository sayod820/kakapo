# ════════════════════════════════════════════
# KAKAPO Frontend — настройки
# ════════════════════════════════════════════

# Использовать backend API (true) или демо-данные (false)
NEXT_PUBLIC_USE_API=false

# Адрес backend сервера (опционально — по умолчанию https://kakapo-api.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Vercel / продакшен (достаточно только USE_API=true — запросы идут через /api/kakapo proxy):
# NEXT_PUBLIC_USE_API=true
# NEXT_PUBLIC_WS_URL=wss://kakapo-api.onrender.com
