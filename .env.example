# ── Production: Vercel (frontend) + Render (backend) ─────────────────
# Vercel → Settings → Environment Variables (Production):
NEXT_PUBLIC_USE_API=true
NEXT_PUBLIC_API_URL=https://kakapo-api.onrender.com
NEXT_PUBLIC_WS_URL=wss://kakapo-api.onrender.com
KAKAPO_BACKEND_URL=https://kakapo-api.onrender.com

# Render → Web Service kakapo-api (Root Directory: server):
#   Health: /health
#   CORS_ORIGINS=*  (или ваш домен Vercel)

# ── Только демо в браузере (без сервера) ─────────────────────────────
# NEXT_PUBLIC_USE_API=false

# ── Локальная разработка на ПК ───────────────────────────────────────
# NEXT_PUBLIC_USE_API=true
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
# KAKAPO_BACKEND_URL=http://localhost:8000
