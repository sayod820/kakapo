# Ваш домен (без https://)
DOMAIN=kakappo.shop

# Публичные URL для сборки Next.js (обязательно https/wss после SSL)
PUBLIC_URL=https://kakappo.shop
WS_URL=wss://kakappo.shop

# CORS для API
CORS_ORIGINS=https://kakappo.shop,https://www.kakappo.shop

# ИИ-ассистент админки (Google AI Studio → Create API key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Email для Let's Encrypt (ssl-init.sh)
CERTBOT_EMAIL=admin@kakappo.shop

# Путь к репозиторию на сервере (setup-server.sh)
KAKAPO_REPO_DIR=/opt/kakapo
