# Скопируйте в .env и заполните:
#   cp deploy/hetzner/.env.example deploy/hetzner/.env

# Ваш домен (без https://)
DOMAIN=kakapo.tj

# Публичные URL для сборки Next.js (обязательно https/wss после SSL)
PUBLIC_URL=https://kakapo.tj
WS_URL=wss://kakapo.tj

# CORS для API (можно * или ваш домен)
CORS_ORIGINS=https://kakapo.tj

# ИИ-ассистент админки (Google AI Studio → Create API key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Email для Let's Encrypt (ssl-init.sh)
CERTBOT_EMAIL=admin@kakapo.tj

# Путь к репозиторию на сервере (setup-server.sh)
KAKAPO_REPO_DIR=/opt/kakapo
