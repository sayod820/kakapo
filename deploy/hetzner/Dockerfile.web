# Next.js frontend — все приложения (store, admin, courier, restaurant, assembler)
FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

ARG NEXT_PUBLIC_USE_API=true
ARG KAKAPO_BACKEND_URL=http://api:8000
ARG NEXT_PUBLIC_API_URL=
ARG NEXT_PUBLIC_WS_URL=

ENV NEXT_PUBLIC_USE_API=$NEXT_PUBLIC_USE_API
ENV KAKAPO_BACKEND_URL=$KAKAPO_BACKEND_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NODE_ENV=production

RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public

EXPOSE 3000
CMD ["npm", "start"]
