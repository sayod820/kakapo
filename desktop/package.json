{
  "name": "kakapo-trade-desktop",
  "version": "1.1.7",
  "private": true,
  "description": "КАКАПО Касса — одно приложение: чеки, этикетки, оборудование",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "pack": "electron-builder --win dir",
    "dist": "electron-builder --win nsis"
  },
  "build": {
    "appId": "tj.kakapo.trade",
    "productName": "KAKAPO Kassa",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "casScale.cjs",
      "tsplLabel.cjs",
      "escposReceipt.cjs",
      "receiptTemplate.cjs",
      "icon.png",
      "config.json",
      "package.json"
    ],
    "win": {
      "icon": "icon.png",
      "target": [
        "nsis"
      ],
      "artifactName": "KAKAPO-Kassa-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "KAKAPO Kassa"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  }
}
